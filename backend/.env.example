APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
SLOW_REQUEST_THRESHOLD_MS=1200
REQUEST_LOG_EXCLUDE_PATHS=/api/health

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
AUTH_REQUEST_TIMEOUT_SECONDS=10
AUTH_USER_CACHE_TTL_SECONDS=30
REDIS_URL=
REDIS_CACHE_TTL_SECONDS=120

DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_MODEL_ID=doubao-seed-1-6-flash-250828
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_RETRY_ATTEMPTS=2
AI_RETRY_BACKOFF_SECONDS=0.8
PRACTICE_AI_TIMEOUT_SECONDS=18
PRACTICE_AI_MAX_ATTEMPTS=1
PRACTICE_AI_CACHE_TTL_SECONDS=300
REQUEST_TIMEOUT_SECONDS=60
